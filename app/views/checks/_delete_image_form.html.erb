<%= form_tag checks_destroy_multiple_images_path, method: :get do %>
<% if @check.images.attached? %>
<table class="table table-striped" >
  <thead>
    <tr>
      <th>Image</th>
      <th>Delete</th>
    </tr>
  </thead>

  <tbody>
    <% @check.images.each do |image| %>
      <tr>
        <td><%= image_tag image, class: "w-50 h-auto" %></td>
        <td><%= check_box_tag "deleted_img_ids[]", image.id  %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<% end %>
<%= submit_tag "Delete selected images", class: "btn btn-primary" %>
<% end %>