<%= form_with(model: check) do |form| %>
  <% if check.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(check.errors.count, "error") %> prohibited this inspection from being saved:</h2>

      <ul>
        <% check.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <table class="table">
    <thead>
      <tr>
        <th>Origin</th>
        <th>Destination</th>
        <th>Trip Date</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td> <%= form.text_field :origin %> </td>
        <td> <%= form.text_field :destionation %> </td>
        <td> <%= form.date_field :trip_date %></td>
      </tr>
    </tbody>
  </table>

  <table class="table">
    <thead>
      <tr>
        <th>Truck Tag</th>
        <th>Trailer Tag</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td> <%= form.text_field :truck_tag %> </td>
        <td> <%= form.text_field :trailer_tag %> </td>
      </tr>
    </tbody>
  </table>

  <h3> In Cab 
    <button class="btn btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#cab" aria-expanded="false" aria-controls="cab">Show/Hide 
    </button>
  </h3>
  <div class="collapse" id="cab">
    <table class="table">
      <thead>
        <tr>
          <th>Chocks</th>
          <th>Seat Belt</th>
          <th>ABS Light</th>
          <th>Air Govenor</th>
          <th>Leak Test</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td> <%= form.checkbox :chocks %> </td>
          <td> <%= form.checkbox :seat_belt %> </td>
          <td> <%= form.checkbox :cab_abs %> </td>
          <td> <%= form.checkbox :air_govenor %> </td>
          <td> <%= form.checkbox :leak %> </td>
        </tr>
      </tbody>
    </table>
    <table class="table">
      <thead>
        <tr>
          <th>Low Air</th>
          <th>Pop Out</th>
          <th>Trailer Brake</th>
          <th>Tractor Brake</th>
          <th>Service Brake</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td> <%= form.checkbox :low_air %> </td>
          <td> <%= form.checkbox :pop_out %> </td>
          <td> <%= form.checkbox :trailer_brake %> </td>
          <td> <%= form.checkbox :tractor_brake %> </td>
