    <div class="collapse" id="fifth">
      <table class="table">
        <thead>
          <tr>
            <th>Apron</th>
            <th>Skid Plate</th>
            <th>Pivot Pin</th>
            <th>Lock & Release Handle</th>
            <th>Platform</th>
            <th>Kingpin & Locking Jaw</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td> <%= form.checkbox :apron %> </td>
            <td> <%= form.checkbox :skid_plate %> </td>
            <td> <%= form.checkbox :pivot_pin %> </td>
            <td> <%= form.checkbox :lock_release %> </td>
            <td> <%= form.checkbox :platform %> </td>
            <td> <%= form.checkbox :kingpin %> </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <h3> Faults 
    <button class="btn btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#faults" aria-expanded="false" aria-controls="faults">Show/Hide 
    </button>
  </h3>
  <div class="collapse" id="faults">
    <table class="table">
      <thead>
        <tr>
          <th>Images</th>
          <th>Notes</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td> <%= form.file_field :images, multiple: true %> </td>
          <td> <%= form.text_area :notes %> </td>
        </tr>
      </tbody>
    </table>
  </div>

  <div>
    <%= form.submit "Submit inspection", class: "btn btn-primary" %>
  </div>
<% end %>
